# ═══════════════════════════════════════════════════════════════════════════════
#  School Portal — Environment Configuration
#  Copy this file to .env and edit for your school:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (main database)
# Docker: postgresql+asyncpg://school:school_pass@postgres:5432/school_db
# Local:  postgresql+asyncpg://school:school_pass@localhost:5432/school_db
DATABASE_URL=postgresql+asyncpg://school:school_pass@postgres:5432/school_db

# MongoDB connection string (action logging)
# Docker: mongodb://mongo:27017
# Local:  mongodb://localhost:27017
MONGO_URL=mongodb://mongo:27017

# ─── JWT Authentication ──────────────────────────────────────────────────────

# !!! CHANGE THIS in production: openssl rand -hex 64
JWT_SECRET=change-this-to-a-very-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ─── Application ──────────────────────────────────────────────────────────────

APP_NAME=Электронный дневник
APP_URL=http://localhost:8000
# Set to "false" in production (disable debug error pages)
DEBUG=true

# ─── School Information ──────────────────────────────────────────────────────

SCHOOL_NAME=Частная школа
SCHOOL_CITY=Москва

# ─── File Uploads ────────────────────────────────────────────────────────────

UPLOAD_DIR=app/static/uploads

# ─── Schedule / Timetable ─────────────────────────────────────────────────────

# First lesson start time (HH:MM, 24-hour format)
LESSON_START_TIME=09:00
# Duration of one lesson in minutes
LESSON_DURATION_MINUTES=45
# Maximum lessons per day
MAX_LESSONS_PER_DAY=8
# Working days (comma-separated, 0=Mon .. 6=Sun)
WORKING_DAYS=0,1,2,3,4,5

# ─── Academic Year ────────────────────────────────────────────────────────────

# Start month of the academic year (9 = September)
ACADEMIC_YEAR_START_MONTH=9
# End month
ACADEMIC_YEAR_END_MONTH=5
# End day
ACADEMIC_YEAR_END_DAY=31
# Exam period start date
ACADEMIC_YEAR_EXAM_START=2025-05-25

# ─── Grading ─────────────────────────────────────────────────────────────────

TRIMESTER_COUNT=3
GRADE_MIN=1
GRADE_MAX=5

# ─── Seed Data (test accounts) ───────────────────────────────────────────────

SEED_TEACHER_PASSWORD=teacher123
SEED_STUDENT_PASSWORD=student123
SEED_SECRETARY_PASSWORD=secretary123
